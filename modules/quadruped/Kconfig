menu "Quadruped module"

config QUADRUPED_MODULE
	bool "Enable quadruped module"
	default y
	depends on LEG_MODULE
	help
	  Enable the quadruped controller module.

if QUADRUPED_MODULE

config QUADRUPED_MODULE_INIT_PRIORITY
	int "Quadruped device init priority"
	range 0 999
	default 90
	help
	  Initialization priority for the danovski,quadruped device at POST_KERNEL
	  level. Use a value higher than LEG_MODULE_INIT_PRIORITY to initialize after
	  all leg devices.

config QUADRUPED_MODULE_LOG_LEVEL
	int "Quadruped module log level"
	range 0 4
	default 3
	depends on LOG
	help
	  Log level for the quadruped module.
	  0: off, 1: error, 2: warning, 3: info, 4: debug.

endif

endmenu
